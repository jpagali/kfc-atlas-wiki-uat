{
  "name": "kfc-atlas-portal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prestart": "node scripts/generate-search-index.mjs",
    "prebuild": "node scripts/generate-search-index.mjs",
    "preserve": "node scripts/generate-search-index.mjs",
    "test:weekly-regression": "node scripts/weekly-regression.mjs",
    "docusaurus": "docusaurus",
    "start": "docusaurus build && docusaurus serve --dir build --port 3000",
    "start:dev-en": "docusaurus start --locale en-US --port 3001",
    "start:dev": "docusaurus build && docusaurus serve --dir build --port 3001",
    "build": "docusaurus build",
    "preview": "docusaurus serve --dir build --port 3005",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.5.2",
    "@docusaurus/preset-classic": "^3.5.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@mdx-js/react": "^3.0.0",
    "@tiptap/extension-image": "^3.20.2",
    "@tiptap/extension-link": "^3.20.2",
    "@tiptap/extension-table": "^3.20.2",
    "@tiptap/extension-table-cell": "^3.20.2",
    "@tiptap/extension-table-header": "^3.20.2",
    "@tiptap/extension-table-row": "^3.20.2",
    "@tiptap/extension-underline": "^3.20.2",
    "@tiptap/pm": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/types": "3.9.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
