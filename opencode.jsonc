{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "plugin": [
    "opencode-scheduler"
  ],
  "model": "opencode/mimo-v2-pro-free"
}
